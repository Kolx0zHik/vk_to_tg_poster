#!/usr/bin/env bash
set -euo pipefail

message_file="$1"
source_type="${2:-}"

if [[ "${AUTO_COMMIT_MESSAGE_SKIP:-0}" == "1" ]]; then
  exit 0
fi

if [[ "$source_type" == "merge" || "$source_type" == "squash" ]]; then
  exit 0
fi

if git diff --cached --quiet; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
generated_message="$(python3 "$repo_root/scripts/generate_commit_message.py" --staged)"

if [[ -z "$generated_message" ]]; then
  exit 0
fi

printf '%s\n' "$generated_message" > "$message_file"
